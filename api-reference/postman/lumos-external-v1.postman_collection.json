    },
    {
      "key": "pipelineStageIds",
      "value": "REEMPLAZA_CON_PIPELINE_STAGE_ID_1,REEMPLAZA_CON_PIPELINE_STAGE_ID_2",
      "type": "string"
    },
    {
      "key": "activityId",
      "value": "REEMPLAZA_CON_ACTIVITY_ID",
      "type": "string"
